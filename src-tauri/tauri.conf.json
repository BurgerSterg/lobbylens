{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BurgerLens",
  "version": "0.1.0",
  "identifier": "com.burgerlens.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BurgerLens",
        "width": 1100,
        "height": 700,
        "minWidth": 1100,
        "minHeight": 600,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://media.valorant-api.com; connect-src 'self' https://valorant-api.com https://api.henrikdev.xyz https://pd.na.a.pvp.net https://pd.eu.a.pvp.net https://pd.ap.a.pvp.net https://glz-na-1.na.a.pvp.net https://glz-eu-1.eu.a.pvp.net https://glz-ap-1.ap.a.pvp.net"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
